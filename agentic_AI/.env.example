# Copy this file to .env and fill in the values before running locally.
# Never commit .env to version control.

# Required: OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: path to the Stock Market PDF inside the container
# (defaults to /app/data/Stock_Market_Performance_2024.pdf)
PDF_PATH=/app/data/Stock_Market_Performance_2024.pdf

# Optional: directory where ChromaDB persists its data
# (defaults to /app/chroma_db)
CHROMA_PERSIST_DIR=/app/chroma_db
